<#
.SYNOPSIS
    Disables TLS 1.0 protocol for both Client and Server.

.NOTES
    Author          : Mark Tuazon
    LinkedIn        : linkedin.com/in/mark-t-83a52b145/
    GitHub          : github.com/MarkCyberOps
    Date Created    : 2026-03-21
    Last Modified   : 2026-03-21
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : 104743
    STIG-ID         : WN11-SO-000025

.USAGE
    Run with administrative privileges.

    Example:
    PS C:\> .\04-WN11-SO-000025_Disable-TLS1.0.ps1
#>

$base = "HKLM:\SYSTEM\CurrentControlSet\Control\SecurityProviders\SCHANNEL\Protocols\TLS 1.0"

Write-Output "Checking TLS 1.0 configuration..."

$client = Get-ItemProperty "$base\Client" -ErrorAction SilentlyContinue
$server = Get-ItemProperty "$base\Server" -ErrorAction SilentlyContinue

Write-Output "Client Enabled: $($client.Enabled)"
Write-Output "Server Enabled: $($server.Enabled)"

Write-Output "Applying remediation..."

New-Item "$base\Client" -Force | Out-Null
New-Item "$base\Server" -Force | Out-Null

Set-ItemProperty "$base\Client" -Name Enabled -Value 0 -Type DWord
Set-ItemProperty "$base\Client" -Name DisabledByDefault -Value 1 -Type DWord

Set-ItemProperty "$base\Server" -Name Enabled -Value 0 -Type DWord
Set-ItemProperty "$base\Server" -Name DisabledByDefault -Value 1 -Type DWord

Start-Sleep -Seconds 2

Write-Output "Validating TLS 1.0 configuration..."

$clientNew = Get-ItemProperty "$base\Client"
$serverNew = Get-ItemProperty "$base\Server"

Write-Output "Client Enabled: $($clientNew.Enabled)"
Write-Output "Server Enabled: $($serverNew.Enabled)"

if ($clientNew.Enabled -eq 0 -and $serverNew.Enabled -eq 0) {
    Write-Output "STIG remediation successful: TLS 1.0 disabled."
} else {
    Write-Output "Remediation failed."
}
