<#
.SYNOPSIS
    Enables certificate padding check for WinVerifyTrust.

.NOTES

    Author          : Mark Tuazon
    LinkedIn        : linkedin.com/in/mark-t-83a52b145/
    GitHub          : github.com/MarkCyberOps
    Date Created    : 2026-03-21
    Last Modified   : 2026-03-21
    Version         : 1.0
    CVEs            : N/A
    Author          : Mark Tuazon
    Plugin IDs      : 166555
    STIG-ID         : WN11-SO-000190


.USAGE
    Run with administrative privileges.

    Example:
    PS C:\> .\WN11-SO-000190_WinVerifyTrust.ps1
#>

$path = "HKLM:\Software\Microsoft\Cryptography\Wintrust\Config"

# CHECK
$current = Get-ItemProperty -Path $path -Name EnableCertPaddingCheck -ErrorAction SilentlyContinue
Write-Output "Current Value: $($current.EnableCertPaddingCheck)"

# REMEDIATION
New-Item -Path $path -Force | Out-Null
Set-ItemProperty -Path $path -Name EnableCertPaddingCheck -Value 1 -Type DWord

# VALIDATION
$new = Get-ItemProperty -Path $path -Name EnableCertPaddingCheck
Write-Output "Updated Value: $($new.EnableCertPaddingCheck)"
