<#
.SYNOPSIS
    Enables WinVerifyTrust certificate padding check.

.NOTES
    Author          : Mark Tuazon
    LinkedIn        : linkedin.com/in/mark-t-83a52b145/
    GitHub          : github.com/MarkCyberOps
    Date Created    : 2026-03-21
    Last Modified   : 2026-03-21
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : 166555
    STIG-ID         : WN11-SO-000190
    Remediation Note: Initial remediation did not resolve the finding due to a missing 32-bit registry configuration.
                      The fix was applied to both registry paths (standard and WOW6432Node), followed by a system reboot.

.TESTED ON
    Date(s) Tested  : 2026-03-21
    Tested By       : Mark Tuazon
    Systems Tested  : Windows 11 Pro 25H2
    PowerShell Ver. : 5.1

.USAGE
    Run with administrative privileges.

    Example:
    PS C:\> .\03-WN11-SO-000190_WinVerifyTrust.ps1
#>

$paths = @(
    "HKLM:\Software\Microsoft\Cryptography\Wintrust\Config",
    "HKLM:\Software\WOW6432Node\Microsoft\Cryptography\Wintrust\Config"
)

Write-Output "Applying WinVerifyTrust padding check remediation..."

foreach ($path in $paths) {
    New-Item -Path $path -Force | Out-Null
    Set-ItemProperty -Path $path -Name EnableCertPaddingCheck -Value 1 -Type DWord
    Write-Output "Set EnableCertPaddingCheck at $path"
}

Start-Sleep -Seconds 2

Write-Output "Validating..."

foreach ($path in $paths) {
    $value = Get-ItemProperty -Path $path -Name EnableCertPaddingCheck
    Write-Output "$path = $($value.EnableCertPaddingCheck)"
}
