<#
.SYNOPSIS
    Disables TLS 1.1 protocol.
    
.NOTES
    Author          : Mark Tuazon
    LinkedIn        : linkedin.com/in/mark-t-83a52b145/
    GitHub          : github.com/MarkCyberOps
    Date Created    : 2026-03-21
    Last Modified   : 2026-03-22
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : 157288
    STIG-ID         : WN11-SO-000030

.TESTED ON
    Date(s) Tested  : 2026-03-22
    Tested By       : Mark Tuazon
    Systems Tested  : Windows 11 Pro 25H2
    PowerShell Ver. : 5.1

.USAGE
    Run with administrative privileges.

    Example:
    PS C:\> .\05-WN11-SO-000030_Disable-TLS1.1.ps1
#>

$base = "HKLM:\SYSTEM\CurrentControlSet\Control\SecurityProviders\SCHANNEL\Protocols\TLS 1.1"

Write-Output "Applying TLS 1.1 remediation..."

# Create keys if needed
New-Item "$base\Client" -Force | Out-Null
New-Item "$base\Server" -Force | Out-Null

# Disable TLS 1.1
Set-ItemProperty "$base\Client" -Name Enabled -Value 0 -Type DWord
Set-ItemProperty "$base\Client" -Name DisabledByDefault -Value 1 -Type DWord

Set-ItemProperty "$base\Server" -Name Enabled -Value 0 -Type DWord
Set-ItemProperty "$base\Server" -Name DisabledByDefault -Value 1 -Type DWord

Write-Output "TLS 1.1 has been disabled."

# Validation
Write-Output "Validating settings..."

Get-ItemProperty "$base\Client"
Get-ItemProperty "$base\Server"
